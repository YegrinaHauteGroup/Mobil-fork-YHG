# Supabase — 프로젝트 대시보드 > Settings > API 에서 확인
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Sophia (AI 어시스턴트) — NVIDIA NIM API 키. 서버(Server Action)에서만 쓰이며
# 클라이언트로는 절대 노출되지 않는다. https://build.nvidia.com 에서 발급.
# NVIDIA_API_KEY_2 는 선택 사항 — 두 번째 키를 등록해두면 매 요청마다 둘 중
# 하나로 무작위 로드밸런싱하고, 레이트리밋/장애 시 남은 키로 자동 재시도(failover)한다.
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_KEY_2=nvapi-your-second-key-here

# Big Brother (통합 검색) — GitHub 코드 검색용 Personal Access Token.
# github.com → Settings → Developer settings → Personal access tokens 에서
# public_repo 읽기 권한만 있는 토큰을 발급해 등록한다. 없어도 OpenAlex/
# Semantic Scholar 논문 검색은 정상 동작한다(GitHub 섹션만 비활성).
GITHUB_TOKEN=ghp_your-token-here
